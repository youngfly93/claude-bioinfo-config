{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/bash3_check.py", "timeout": 5 },
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/cjk_shell_check.py", "timeout": 5 },
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/canonical_guard.py", "timeout": 5 }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/canonical_guard.py", "timeout": 5 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/docx_autocheck.py", "timeout": 20 }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/session_preflight.py", "timeout": 8 }
        ]
      }
    ]
  }
}
